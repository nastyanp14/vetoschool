{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vetoschool",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-07-18",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "none",
    "run_worker_first": [
      "/*",
      "!/assets/*"
    ]
  }
}
